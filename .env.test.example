# 测试环境变量配置示例
# 复制此文件为 .env.test 并根据需要修改

# 测试环境标识
TEST_ENV=true

# 前端基础 URL（Vite 开发服务器）
BASE_URL=http://localhost:5173

# 后端 API URL（Express 服务器）
API_URL=http://localhost:3001

# Playwright 配置
# 浏览器类型：chromium, firefox, webkit
BROWSER=chromium

# 是否启用无头模式（CI 环境建议 true）
HEADLESS=true

# 测试超时设置（毫秒）
TEST_TIMEOUT=60000

# 测试重试次数
RETRIES=2

# 并行工作者数量（CI 建议 1，本地可以更高）
WORKERS=4
